{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spacex-image-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-05-28",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
